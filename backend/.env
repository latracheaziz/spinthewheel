PORT=5000

# CONFIGURATION DE L'ENVOI D'EMAILS RÉELS (GMAIL)
# Pour envoyer de vrais emails sur votre boite mail, décommentez et remplissez les lignes ci-dessous :
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=votre-email-gmail@gmail.com
# SMTP_PASS=votre-mot-de-passe-d-application
# SMTP_FROM="Griffin Store <votre-email-gmail@gmail.com>"
#
# NOTE : Pour Gmail, vous devez générer un "Mot de passe d'application" dans la sécurité de votre compte Google :
# 1. Allez sur https://myaccount.google.com/
# 2. Activez la validation en 2 étapes si ce n'est pas déjà fait.
# 3. Recherchez "Mots de passe d'application" (App Passwords) et générez un code à 16 lettres pour "Messagerie".
# 4. Copiez ce code de 16 lettres sans espaces dans SMTP_PASS.

# CONFIGURATION VIA RESEND (Alternative API HTTP - Recommandé pour éviter les blocages de ports SMTP)
# Obtenez une clé gratuite en 10 secondes sur https://resend.com/
#
# RESEND_API_KEY=re_votreCléResendIci
# RESEND_FROM="Griffin Store <onboarding@resend.dev>"
